# raspi-cluster — static configuration TEMPLATE.  Copy to .env and edit:  cp .env.example .env
# lib/common.sh sources your .env, then derives the computed values (node array, install paths,
# build-cache key). Plain KEY=value scalars only — no logic, no arrays, no command substitution.
#
# The IPs / domains / emails / usernames / repo below are FAKE placeholders — replace them with yours.
# The version/digest/identifier values are REAL (the working build recipe + cluster identifiers) — keep
# them as-is unless you are deliberately bumping a version.
#
# SECRETS sit inline in the section they belong to, each named with a _SECRET suffix and left EMPTY here.
# .env is gitignored, so your real tokens/passwords stay out of git — the scripts read them straight from
# .env, they are NOT prompted. Leave a secret empty to skip the feature it enables (see each comment).
# NEVER put a real secret in this committed .env.example template.

# ---- Cluster topology  (nodes / VIP / disk / NIC — step 03) ----  [EDIT THESE]
# Space-separated "hostname:ip" per node; reserve each IP in your router.
CLUSTER_NODES="talos-cp1:192.168.1.11 talos-cp2:192.168.1.12 talos-cp3:192.168.1.13"
CLUSTER_NAME="my-cluster"              # talosctl gen config cluster name
KUBERNETES_VERSION="1.36.2"            # k8s the cluster runs: talosctl gen config targets it (03d), 03g upgrades to it, 03e's dockerized kubectl tag matches it. No 'v'. Ceiling = the pinned Talos's default (v1.13.4 -> 1.36.1); to go higher, bump TALOS_VERSION first
CLUSTER_VIP="192.168.100.1"            # control-plane VIP (unused IP, outside your DHCP pool)
API_PORT=50000                         # Talos API port
EXPECT_NIC="end0"                      # Pi 5 wired NIC (the VIP binds to it)
EXPECT_DISK="nvme0n1"                  # the NVMe (install target)
EPHEMERAL_SIZE="64GiB"                 # EPHEMERAL cap; rest of the NVMe -> cnpg (fixed) + longhorn (remainder)
CNPG_VOLUME_SIZE="50GiB"               # fixed-size 'cnpg' user volume (local-path-provisioner backs CNPG)
NODE_INSTANCE_TYPE="rpi5"              # node.kubernetes.io/instance-type label (nic-keeper selector)

# ---- Image build — versions + extensions  (step 03 image build) ----  [REAL recipe — keep as-is]
TALOS_VERSION="v1.13.5"                # siderolabs/talos; also the talosctl client + expected server
PKG_VERSION="v1.13.0"                  # siderolabs/pkgs (matches Talos minor; ships the 6.18 base config)
BUILDER_VERSION="v1.11.5"              # talos-rpi5/talos-builder release (the Makefile scaffold)
SBCOVERLAY_VERSION="7d04484be2beb4b1fca56538d2b6d07e7d58681f"  # talos-rpi5/sbc-raspberrypi5 commit (no tags)
KERNEL_REF="stable_20260609"           # raspberrypi/linux tag on rpi-6.18.y (== Linux 6.18.34)
# Digest-pinned system extensions for this Talos version (factory.talos.dev .../extensions/official):
ISCSI_EXT="ghcr.io/siderolabs/iscsi-tools:v0.2.0@sha256:12521145e65403037a7412bf9abce1efd08583e018e5eed8e1c5b9faf52d1da4"
UTIL_EXT="ghcr.io/siderolabs/util-linux-tools:2.41.4@sha256:3f0105dd85607dcd81ee12703c0f432f32159cde430dfe16b5112e76e9d5a5d4"
GITHUB_GHCR_PUSH_TOKEN_SECRET=""       # SECRET classic PAT, write:packages — 03a docker-login + push of the installer image (build host only; empty = build/validate but don't publish)

# ---- Shared Kubernetes identifiers  (used across 07/12/15/16) ----  [REAL — keep as-is]
SS_CONTROLLER_NS="sealed-secrets"      # kubeseal --controller-namespace (matches 02_sealed_secrets)
SS_CONTROLLER_NAME="sealed-secrets"    # kubeseal --controller-name
SS_POD_SELECTOR="app.kubernetes.io/name=sealed-secrets"      # the controller pods
SS_KEY_LABEL="sealedsecrets.bitnami.com/sealed-secrets-key"  # label on its key Secrets
MONITORING_NS="monitoring"             # the monitoring stack namespace (15/16)

# ---- GHCR registry  (step 03a build/publish, 03d node pull auth) ----
GHCR_SERVER="ghcr.io"                  # registry host the auth is scoped to  [keep]
GHCR_USER="your-github-username"       # GitHub username the tokens belong to (also the GHCR namespace)  [EDIT]
INSTALLER_PACKAGE="talos-installer"    # GHCR package name 03a publishes the Talos installer to (03f upgrades from it)  [keep]
GITHUB_GHCR_PULL_TOKEN_SECRET=""       # SECRET classic PAT, read:packages — 03d bakes it into every node so kubelet pulls PRIVATE ghcr.io images (empty = public only)

# ---- GitOps / ArgoCD  (step 05) ----  [EDIT]
# Must equal the repoURL committed across argo_apps/ (https form, no trailing .git).
REPO_URL="https://github.com/yama6a/pi5-k8s-cluster"
ARGOCD_GITHUB_PAT_SECRET=""            # SECRET fine-grained, read-only, single-repo PAT — 05 seeds ArgoCD's repo-creds Secret (empty = anonymous clone, PUBLIC repo only)

# ---- Networking + domains  (step 04 Cilium LB-IPAM, step 10 gateway) ----  [EDIT]
LB_RANGE_START="192.168.100.200"       # CiliumLoadBalancerIPPool start (same L2 as nodes, outside DHCP)
LB_RANGE_STOP="192.168.100.250"        # ... pool end
LE_EMAIL="you@example.com"             # ACME registration email for the Let's Encrypt ClusterIssuers
BASE_DOMAIN="example.com"              # base domain for cluster-hosted app hostnames
GOOGLE_SSO_CLIENT_ID=""                # Google OAuth client id (*.apps.googleusercontent.com) — 07 writes it into the google-sso values (REQUIRED for SSO; not a secret, but paired with the secret below)
GOOGLE_SSO_CLIENT_SECRET=""            # SECRET Google OAuth client secret — 07 seals it for Envoy Gateway OIDC (REQUIRED for SSO)

# ---- SMTP  (step 09 Grafana) ----
SMTP_SMARTHOST="smtp.gmail.com:587"    # SMTP smarthost (host:port) Grafana relays through  [EDIT host if not Gmail]
SMTP_SECRET_KEY="password"             # data key in the sealed SMTP secret (the app password itself is below)
SMTP_GOOGLE_APP_PASSWORD_SECRET=""     # SECRET 16-char Gmail app password (needs 2-Step Verification) — 09 seals it for Grafana email (empty = disable outgoing email)
