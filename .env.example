# raspi-cluster — personal config + secrets TEMPLATE.  Copy to .env and edit:  cp .env.example .env
# lib/shell/common.sh sources versions.env (committed recipe) THEN your .env, then derives the computed
# values (node array, install paths, build-cache key). Plain KEY=value scalars only — no logic, no arrays,
# no command substitution. Two portions: CONFIG (non-secret, edit for your setup) then SECRETS.
#
# The IPs / domains / emails / usernames / repo below are FAKE placeholders — replace them with yours.
# Versions live in the COMMITTED versions.env (renovate-managed), not here.
#
# Every SECRET is left EMPTY here. .env is gitignored, so your real tokens/passwords stay out of git — the
# scripts read them straight from .env, they are NOT prompted. Leave a secret empty to skip the feature it
# enables (see each comment). NEVER put a real secret in this committed .env.example template.

# =============================================================================================
# CONFIG — non-secret, per-deployment values (topology, domains, tuning). Edit for your setup.
# =============================================================================================

# ---- Cluster topology  (nodes / VIP — step 03) ----
# Space-separated "hostname:ip" per node; reserve each IP in your router.
CLUSTER_NODES="talos-cp1:192.168.1.11 talos-cp2:192.168.1.12 talos-cp3:192.168.1.13"
CLUSTER_NAME="my-cluster"              # talosctl gen config cluster name
CLUSTER_VIP="192.168.100.1"            # control-plane VIP (unused IP, outside your DHCP pool)
EPHEMERAL_SIZE="64GiB"                 # EPHEMERAL cap; rest of the NVMe -> localpath (fixed) + longhorn (remainder)
LOCALPATH_VOLUME_SIZE="50GiB"          # fixed-size 'localpath' user volume (backs the local-path-provisioner: CNPG + RabbitMQ)

# ---- GHCR registry  (step 03a build/publish, 03d node pull auth) ----
GHCR_USER="your-github-username"       # GitHub username the tokens belong to (also the GHCR namespace)

# ---- GitOps / ArgoCD  (step 05) ----
# REPO_URL must equal the repoURL committed across argo_apps/ (https form, no trailing .git).
REPO_URL="https://github.com/yama6a/pi5-k8s-cluster"
POLL_SYNC_ENABLED="false"              # ArgoCD git-poll cadence. 08_argocd_webhook.sh patches timeout.reconciliation from this: false=300s (webhook-driven; the poll is just a 5-min safety net) / true=60s (fast poll). The GitHub webhook is the fast sync path either way. See docs/05_gitops.md. The webhook shared secret is NOT here — 08 generates it into secrets/

# ---- Networking + domains  (step 04 Cilium LB-IPAM, step 10 gateway) ----
LB_RANGE_START="192.168.100.200"       # CiliumLoadBalancerIPPool start (same L2 as nodes, outside DHCP)
LB_RANGE_STOP="192.168.100.250"        # ... pool end
LE_EMAIL="you@example.com"             # ACME registration email for the Let's Encrypt ClusterIssuers
CLOUDFLARE_WILDCARD_DOMAINS=""                    # space-separated domains to serve via Cloudflare DNS-01 wildcard certs — list each host TIER you host (e.g. "ops.example.com app.example.com example.com"). Cloudflare auto-detects the registrable zone; the token (below) just needs edit rights on it. Empty = DNS-01 off, HTTP-01 per-host for all (07 propagates this into the gateway + ingress-lib values)

# ---- S3 backups — Terraform bucket + CNPG/Redis/Longhorn/VM-Logs backups  (steps 13/14/15/16/17) ----
AWS_REGION="eu-central-1"              # AWS region for the backup bucket (Terraform + the CNPG S3 endpoint)
S3_BACKUP_BUCKET="my-cluster-backups"  # globally-unique bucket for ALL backups (prefixes cnpg/, redis/, longhorn/, vm/)
S3_BACKUP_TRANSITION_DAYS="30"         # lifecycle: age at which objects move to Glacier Instant Retrieval
S3_BACKUP_RETENTION_DAYS="180"         # lifecycle: age at which objects are deleted (= the recovery window)
CNPG_BACKUP_RPO="15min"                # WAL archive_timeout => at most this much committed data lost on a primary failure (Postgres duration string)

# ====================================================================================================
# SECRETS — credentials; NEVER commit or share. Empty here on purpose; each empty = skip that feature.
# ====================================================================================================

GITHUB_GHCR_PUSH_TOKEN_SECRET=""       # classic PAT, write:packages — 03a docker-login + push of the installer image (build host only; empty = build/validate but don't publish)
GITHUB_GHCR_PULL_TOKEN_SECRET=""       # classic PAT, read:packages — 03d bakes it into every node so kubelet pulls PRIVATE ghcr.io images (empty = public only)
ARGOCD_GITHUB_PAT_SECRET=""            # fine-grained, read-only, single-repo PAT — 05 seeds ArgoCD's repo-creds Secret (empty = anonymous clone, PUBLIC repo only)
GOOGLE_SSO_CLIENT_ID=""                # Google OAuth client id (*.apps.googleusercontent.com) — 07 writes it into the google-sso values (REQUIRED for SSO)
GOOGLE_SSO_CLIENT_SECRET=""            # Google OAuth client secret (pairs with GOOGLE_SSO_CLIENT_ID) — 07 seals it for Envoy Gateway OIDC (REQUIRED for SSO)
CLOUDFLARE_API_TOKEN_SECRET=""         # scoped Cloudflare API token (Zone:DNS:Edit + Zone:Read on the parent Cloudflare zone of your CLOUDFLARE_WILDCARD_DOMAINS) — 07 seals it into cert-manager for DNS-01 wildcard issuance (empty = DNS-01 disabled -> HTTP-01 fallback everywhere)
NTFY_PHONE_PASSWORD_SECRET=""          # password for the ntfy 'phone' user (Android app login) — 10 seeds it (empty = disable ntfy alerting)
AWS_DEPLOY_ACCESS_KEY_ID=""            # AWS deployer access key id (pairs with the secret below) — Terraform ONLY (s3:* on the bucket + iam:* on the writer; EXACT policy in docs/13_backups.md). Empty = skip backups (13/14/15/16/17 no-op). NOT sealed into the cluster
AWS_DEPLOY_SECRET_ACCESS_KEY_SECRET="" # AWS deployer secret access key — Terraform only, never enters the cluster
