# lib/shell/common.sh sources this alongside the gitignored .env
# To bump: edit here or let renovate (renovate.json5 customManagers + docs/14_renovate.md)
# Personal config + secrets live in the gitignored .env instead (template .env.example).

## Kubernetes version that the cluster runs. used by 03d, 03e scripts
## Version is CAPPED by Talos release's k8s default
# renovate: datasource=github-releases depName=kubernetes/kubernetes
KUBERNETES_VERSION="1.36.2"

## siderolabs/talos; also the talosctl client + expected server
# renovate: datasource=github-releases depName=siderolabs/talos
TALOS_VERSION="v1.13.5"

## siderolabs/pkgs (matches Talos minor; ships the base kernel config)
# renovate: datasource=github-releases depName=siderolabs/pkgs
PKG_VERSION="v1.13.0"

## talos-rpi5/talos-builder release (the Makefile scaffold)
# renovate: datasource=github-releases depName=talos-rpi5/talos-builder
BUILDER_VERSION="v1.11.5"

## talos-rpi5/sbc-raspberrypi5 main branch git commit hash (renovated via custom manager)
SBCOVERLAY_VERSION="7d04484be2beb4b1fca56538d2b6d07e7d58681f"

## raspberrypi/linux tag on rpi-6.18.y
# renovate: datasource=github-tags depName=raspberrypi/linux
KERNEL_REF="stable_20260609"

## Digest-pinned system extensions for this Talos version (factory.talos.dev .../extensions/official):
# renovate: datasource=docker
ISCSI_EXT="ghcr.io/siderolabs/iscsi-tools:v0.2.0@sha256:12521145e65403037a7412bf9abce1efd08583e018e5eed8e1c5b9faf52d1da4"
# renovate: datasource=docker
UTIL_EXT="ghcr.io/siderolabs/util-linux-tools:2.41.4@sha256:3f0105dd85607dcd81ee12703c0f432f32159cde430dfe16b5112e76e9d5a5d4"
