{
  // Renovate config. Opens dependency-update PRs for EVERY pin in the repo:
  //  - helm chart deps (Chart.yaml + Chart.lock + vendored charts/*.tgz)   -> helmv3
  //  - container images in values.yaml (single-string + repository/tag)     -> helm-values
  //  - the aws terraform provider (versions.tf + .terraform.lock.hcl)       -> terraform
  //  - the renovate workflow's own action pins                              -> github-actions
  //  - images in chart templates + shell scripts, and versions.env          -> customManagers (regex)
  //    Talos/kernel build recipe
  // Cadence is the GHA cron (every 3h — frequent so Renovate can self-merge the combined PR; see below). No
  // internal `schedule`, so a manual workflow_dispatch works too.
  // Run self-hosted by .github/workflows/renovate.yaml. Docs: docs/14_renovate.md.
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    ":dependencyDashboard", // one issue listing every pending/failed update (needs repo Issues enabled)
    "helpers:pinGitHubActionDigestsToSemver", // action pins carry a readable version alongside the digest
  ],
  prConcurrentLimit: 12,
  prHourlyLimit: 0, // no hourly throttle
  dependencyDashboardTitle: "Renovate dependency dashboard",

  // Automerge via Renovate ITSELF, not GitHub's native auto-merge (which needs a branch-protection gate we
  // don't have). Renovate merges the PR through the API once it's mergeable; with no CI checks that is ~2h
  // after creation, on a SUBSEQUENT run — which is why the GHA cron runs every 3h, not weekly.
  platformAutomerge: false,

  // helmv3 auto-discovers every Chart.yaml. Refresh the committed vendored subchart tarballs + Chart.lock
  // on a bump (the repo commits charts/*.tgz, e.g. lib/helm/pg-cluster). file:// deps have no datasource so
  // Renovate skips them. NOTE: do NOT add a "**/charts/**" disable rule — the wrapper charts themselves live
  // under paths containing /charts/, so that would disable the whole repo.
  postUpdateOptions: ["helmUpdateSubChartArchives"],

  // Bumping this file re-vendors an upstream release manifest verbatim (per its README curl recipe), not a
  // line edit — never let a bot patch the image tag inside it.
  ignorePaths: ["argo_apps/platform/charts/03_barman_cloud_plugin/templates/**"],

  customManagers: [
    {
      // Container images annotated `# renovate: datasource=docker` in files helm-values can't read: chart
      // templates (redis-instance), shell-script literals, and the versions.env system extensions. (Images
      // in values.yaml are handled by helm-values — NOT here — to avoid double-managing.)
      // Captures repo:tag(+@sha256 digest) from the ref itself, so the tag AND digest stay fresh.
      customType: "regex",
      description: "docker image refs (annotated) in chart templates, shell scripts, versions.env",
      managerFilePatterns: [
        "/^versions\\.env$/",
        "/^lib/shell/.*\\.sh$/",
        "/^lib/helm/redis-instance/templates/redis\\.yaml$/",
        "/^argo_apps/platform/charts/07_redis_backup/templates/cronjob\\.yaml$/", // alpine/k8s + opstree-redis refs
      ],
      matchStrings: [
        "# renovate: datasource=docker(?: versioning=(?<versioning>\\S+))?\\s+[^\\n]*?(?<depName>[a-z0-9][a-z0-9._/-]+):(?<currentValue>[\\w][\\w.-]*)(?:@(?<currentDigest>sha256:[a-f0-9]{64}))?",
      ],
      datasourceTemplate: "docker",
    },
    {
      // Scalar version vars in versions.env carrying a full `# renovate: datasource=... depName=...` comment
      // (Talos / pkgs / talos-builder / kernel / kubernetes). SBCOVERLAY is handled separately below.
      customType: "regex",
      description: "annotated version scalars in versions.env",
      managerFilePatterns: ["/^versions\\.env$/"],
      matchStrings: [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+\\w+=\"(?<currentValue>[^\"]+)\"",
      ],
    },
    {
      // The sbc-raspberrypi5 overlay is pinned to a bare commit SHA (the repo has no tags); 03a clones `main`
      // then checks out this SHA. Track main's HEAD and keep the SHA fresh via git-refs.
      customType: "regex",
      description: "sbc-raspberrypi5 overlay commit pin",
      managerFilePatterns: ["/^versions\\.env$/"],
      matchStrings: ["SBCOVERLAY_VERSION=\"(?<currentDigest>[a-f0-9]{40})\""],
      currentValueTemplate: "main",
      depNameTemplate: "talos-rpi5/sbc-raspberrypi5",
      packageNameTemplate: "https://github.com/talos-rpi5/sbc-raspberrypi5",
      datasourceTemplate: "git-refs",
    },
    {
      // Kernel pin — tracked INDIRECTLY via raspberrypi/FIRMWARE, not the linux repo. The linux repo's stable_
      // tags are best-effort and jump kernel lines (stable_20260715 was 6.12.95), and rpi-6.18.y HEAD is
      // bleeding-edge. firmware 'stable' HEAD is the RPi-OS-blessed release pointer; 03a derefs its
      // extra/git_hash to the exact tested 6.18 kernel commit. Moves at RPi release cadence (~monthly).
      customType: "regex",
      description: "kernel pin: raspberrypi/firmware stable HEAD (03a derefs extra/git_hash)",
      managerFilePatterns: ["/^versions\\.env$/"],
      matchStrings: ["FIRMWARE_REF=\"(?<currentDigest>[a-f0-9]{40})\""],
      currentValueTemplate: "stable",
      depNameTemplate: "raspberrypi/firmware",
      packageNameTemplate: "https://github.com/raspberrypi/firmware",
      datasourceTemplate: "git-refs",
    },
  ],

  packageRules: [
    {
      // ONE combined, AUTO-MERGED PR for every NON-major update (minor + patch + digest + pin + lockfile).
      // Renovate self-merges it once mergeable (~2h after creation, no CI gate). WARNING: this reaches the live
      // cluster unattended via ArgoCD self-heal — including Cilium (which can cut the cluster off its own
      // network) and any local-path tag bump (which really needs a manual re-vendor, see below); it also bumps
      // the Talos/kernel versions.env recipe, which a merge does NOT apply (that needs a manual rebuild — 03a). Accepted
      // trade-off for a hands-off homelab. To de-risk later: add `minimumReleaseAge` so bumps bake first, or
      // drop `automerge` from the deps you want to gate. See docs/14_renovate.md.
      description: "combine all non-major updates into one auto-merged PR",
      matchUpdateTypes: ["minor", "patch", "digest", "pin", "lockFileMaintenance"],
      groupName: "all non-major dependencies",
      automerge: true,
    },
    // MAJOR updates get their own PR each (Renovate default) — a breaking bump is reviewed in isolation, never
    // bundled. The VictoriaMetrics charts are the one exception: their CRDs must match the operator, so their
    // majors are kept together in a single PR.
    {
      description: "keep VictoriaMetrics majors together (CRDs must match the operator)",
      matchPackageNames: ["victoria-metrics-operator", "victoria-metrics-operator-crds", "victoria-metrics-k8s-stack", "victoria-logs-collector"],
      matchUpdateTypes: ["major"],
      groupName: "victoriametrics stack (major)",
    },
    {
      // k8s release tags are v-prefixed; the versions.env value is not. Strip the v when comparing.
      description: "kubernetes tags are v-prefixed",
      matchPackageNames: ["kubernetes/kubernetes"],
      extractVersion: "^v(?<version>.+)$",
    },
    {
      // local-path-provisioner ships as VENDORED upstream manifests keyed to values.image.tag — a bump must be
      // re-diffed against the upstream release by hand. Label it so, if it changed, you split it out of the
      // combined PR and re-vendor before merging. busybox is its helper image, same chart, same treatment.
      description: "needs-revendor: local-path-provisioner",
      matchManagers: ["helm-values"],
      matchFileNames: ["argo_apps/platform/charts/02_local_path_provisioner/values.yaml"],
      addLabels: ["needs-revendor"],
    },
    {
      // Pin the workflow's action refs to commit digests (supply-chain hardening); the semver-comment helper
      // above keeps a readable version beside each digest.
      description: "pin github action refs to digests",
      matchManagers: ["github-actions"],
      pinDigests: true,
    },
  ],
}
